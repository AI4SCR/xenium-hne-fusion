# Copy to .env and fill in paths for your machine.
# Loaded via: from dotenv import load_dotenv; load_dotenv()

# Root for all data (can point to a scratch or external drive)
DATA_ROOT=data

# HuggingFace token — required for gated datasets (e.g. MahmoodLab/hest)
# Get from https://huggingface.co/settings/tokens
# Also requires accepting dataset terms at huggingface.co/datasets/MahmoodLab/hest
HF_TOKEN=hf_...
