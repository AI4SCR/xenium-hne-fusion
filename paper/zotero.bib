@article{vangassen_flowsomusingselforganizing_2015,
	title = {{FlowSOM}: {Using} self-organizing maps for visualization and interpretation of cytometry data},
	volume = {87},
	copyright = {© 2015 International Society for Advancement of Cytometry},
	issn = {1552-4930},
	shorttitle = {{FlowSOM}},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1002/cyto.a.22625},
	doi = {10.1002/cyto.a.22625},
	abstract = {The number of markers measured in both flow and mass cytometry keeps increasing steadily. Although this provides a wealth of information, it becomes infeasible to analyze these datasets manually. When using 2D scatter plots, the number of possible plots increases exponentially with the number of markers and therefore, relevant information that is present in the data might be missed. In this article, we introduce a new visualization technique, called FlowSOM, which analyzes Flow or mass cytometry data using a Self-Organizing Map. Using a two-level clustering and star charts, our algorithm helps to obtain a clear overview of how all markers are behaving on all cells, and to detect subsets that might be missed otherwise. R code is available at https://github.com/SofieVG/FlowSOM and will be made available at Bioconductor. © 2015 International Society for Advancement of Cytometry},
	language = {en},
	number = {7},
	urldate = {2026-01-31},
	journal = {Cytometry Part A},
	author = {Van Gassen, Sofie and Callebaut, Britt and Van Helden, Mary J. and Lambrecht, Bart N. and Demeester, Piet and Dhaene, Tom and Saeys, Yvan},
	year = {2015},
	note = {\_eprint: https://onlinelibrary.wiley.com/doi/pdf/10.1002/cyto.a.22625},
	keywords = {Key terms: polychromatic flow cytometry, bioinformatics, exploratory data analysis, mass cytometry, self-organizing map, visualization method},
	pages = {636--645},
}

@article{ramos_mechanismbasedcancertherapy_2015,
	title = {Mechanism-based cancer therapy: resistance to therapy, therapy for resistance},
	volume = {34},
	copyright = {2015 Macmillan Publishers Limited},
	issn = {1476-5594},
	shorttitle = {Mechanism-based cancer therapy},
	url = {https://www.nature.com/articles/onc2014314},
	doi = {10.1038/onc.2014.314},
	abstract = {The introduction of targeted therapy promised personalized and efficacious cancer treatments. However, although some targeted therapies have undoubtedly improved prognosis and outcome for specific cancer patients, the recurrent problem of therapeutic resistance subdues present revolutionary claims in this field. The plasticity of tumor cells leads to the development of drug resistance by distinct mechanisms: (1) mutations in the target, (2) reactivation of the targeted pathway, (3) hyperactivation of alternative pathways and (4) cross-talk with the microenvironment. Moreover, the intra-tumor heterogeneity of most tumors can also limit therapeutic response. Interestingly, the early identification of some mechanisms of resistance led to the use of alternative agents that improved clinical benefit, demonstrating that an understanding of the molecular mechanisms driving resistance to specific therapies is of paramount importance. Here we review the most generalized mechanisms of resistance to targeted therapies, together with some experimental strategies employed to identify such mechanisms. Therapeutic failure is not an option and we need to understand the dynamics of tumor adaptation in order to adequately adjust therapies; in essence ‘to fight fire with fire’.},
	language = {en},
	number = {28},
	urldate = {2026-01-31},
	journal = {Oncogene},
	publisher = {Nature Publishing Group},
	author = {Ramos, P. and Bentires-Alj, M.},
	month = jul,
	year = {2015},
	keywords = {Targeted therapies},
	pages = {3617--3626},
}

@misc{mcinnes_umapuniformmanifold_2020,
	title = {{UMAP}: {Uniform} {Manifold} {Approximation} and {Projection} for {Dimension} {Reduction}},
	shorttitle = {{UMAP}},
	url = {http://arxiv.org/abs/1802.03426},
	doi = {10.48550/arXiv.1802.03426},
	abstract = {UMAP (Uniform Manifold Approximation and Projection) is a novel manifold learning technique for dimension reduction. UMAP is constructed from a theoretical framework based in Riemannian geometry and algebraic topology. The result is a practical scalable algorithm that applies to real world data. The UMAP algorithm is competitive with t-SNE for visualization quality, and arguably preserves more of the global structure with superior run time performance. Furthermore, UMAP has no computational restrictions on embedding dimension, making it viable as a general purpose dimension reduction technique for machine learning.},
	urldate = {2026-01-31},
